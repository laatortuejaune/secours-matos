# Base de données Turso (libSQL)
# En local : laisser vide → utilise automatiquement prisma/dev.db
# En production : renseigner les valeurs Turso
TURSO_DATABASE_URL=libsql://votre-base.turso.io
TURSO_AUTH_TOKEN=votre-token-turso

# Vercel Blob (upload photos)
# Généré automatiquement si vous activez Blob Storage dans votre projet Vercel
BLOB_READ_WRITE_TOKEN=votre-token-blob

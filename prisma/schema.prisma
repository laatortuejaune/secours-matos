generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Sac {
  id           Int      @id @default(autoincrement())
  nom          String
  photo        String?
  localisation String?
  description  String?
  vehiculeId   Int?
  createdAt    DateTime @default(now())

  vehicule      Vehicule?      @relation(fields: [vehiculeId], references: [id], onDelete: SetNull)
  compartiments Compartiment[]
  checkups      Checkup[]
  interventions Intervention[]
  taches        Tache[]
  scelles       Scelle[]
}

model Vehicule {
  id              Int      @id @default(autoincrement())
  nom             String
  immatriculation String?
  type            String   @default("autre")
  statut          String   @default("operationnel")
  notes           String?
  createdAt       DateTime @default(now())

  sacs          Sac[]
  taches        Tache[]
  hygiene       ProtocoHygiene[]
  carnetEntries CarnetBord[]
}

model Compartiment {
  id    Int     @id @default(autoincrement())
  nom   String
  photo String?
  ordre Int     @default(0)
  sacId Int

  sac      Sac       @relation(fields: [sacId], references: [id], onDelete: Cascade)
  articles Article[]
}

model Article {
  id              Int       @id @default(autoincrement())
  nom             String
  photo           String?
  codeBarre       String?
  quantiteRequise Int       @default(1)
  datePeremption  DateTime?
  compartimentId  Int
  stockId         Int?

  compartiment    Compartiment     @relation(fields: [compartimentId], references: [id], onDelete: Cascade)
  stock           Stock?           @relation(fields: [stockId], references: [id], onDelete: SetNull)
  checkupArticles CheckupArticle[]
}

model Stock {
  id                 Int       @id @default(autoincrement())
  nom                String
  photo              String?
  codeBarre          String?
  quantiteDisponible Int       @default(0)
  datePeremption     DateTime?
  seuilAlerte        Int       @default(5)

  articles Article[]
}

model Checkup {
  id     Int      @id @default(autoincrement())
  sacId  Int
  date   DateTime @default(now())
  note   String?
  scelle String?

  sac             Sac              @relation(fields: [sacId], references: [id], onDelete: Cascade)
  checkupArticles CheckupArticle[]
}

model CheckupArticle {
  id                Int    @id @default(autoincrement())
  checkupId         Int
  articleId         Int
  quantiteTrouvee   Int    @default(0)
  quantiteManquante Int    @default(0)
  quantitePrelevee  Int    @default(0)
  statut            String @default("ok")
  notes             String?

  checkup Checkup @relation(fields: [checkupId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Intervention {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(now())
  lieu        String
  description String?
  responsable String?
  sacId       Int
  createdAt   DateTime @default(now())

  sac Sac @relation(fields: [sacId], references: [id], onDelete: Cascade)
}

model Tache {
  id           Int       @id @default(autoincrement())
  titre        String
  description  String?
  statut       String    @default("en_cours")
  priorite     String    @default("normale")
  vehiculeId   Int?
  sacId        Int?
  assigneA     String?
  dateEcheance DateTime?
  dateCree     DateTime  @default(now())

  vehicule Vehicule? @relation(fields: [vehiculeId], references: [id], onDelete: SetNull)
  sac      Sac?      @relation(fields: [sacId], references: [id], onDelete: SetNull)
}

model ProtocoHygiene {
  id            Int    @id @default(autoincrement())
  nom           String
  description   String?
  frequenceDays Int    @default(7)
  vehiculeId    Int?

  vehicule Vehicule?       @relation(fields: [vehiculeId], references: [id], onDelete: SetNull)
  records  HygieneRecord[]
}

model HygieneRecord {
  id         Int      @id @default(autoincrement())
  protocolId Int
  date       DateTime @default(now())
  agent      String
  notes      String?
  conforme   Boolean  @default(true)

  protocol ProtocoHygiene @relation(fields: [protocolId], references: [id], onDelete: Cascade)
}

model Scelle {
  id      Int      @id @default(autoincrement())
  sacId   Int
  numero  String
  date    DateTime @default(now())
  posePar String?
  actif   Boolean  @default(true)
  notes   String?

  sac Sac @relation(fields: [sacId], references: [id], onDelete: Cascade)
}

model CarnetBord {
  id          Int      @id @default(autoincrement())
  vehiculeId  Int
  date        DateTime @default(now())
  type        String
  valeur      Float?
  description String?
  agent       String?

  vehicule Vehicule @relation(fields: [vehiculeId], references: [id], onDelete: Cascade)
}

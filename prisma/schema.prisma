generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Sac {
  id        Int      @id @default(autoincrement())
  nom       String
  photo     String?
  createdAt DateTime @default(now())

  compartiments Compartiment[]
  checkups      Checkup[]
}

model Compartiment {
  id    Int     @id @default(autoincrement())
  nom   String
  photo String?
  ordre Int     @default(0)
  sacId Int

  sac      Sac       @relation(fields: [sacId], references: [id], onDelete: Cascade)
  articles Article[]
}

model Article {
  id              Int       @id @default(autoincrement())
  nom             String
  photo           String?
  codeBarre       String?
  quantiteRequise Int       @default(1)
  datePeremption  DateTime?
  compartimentId  Int
  stockId         Int?

  compartiment    Compartiment     @relation(fields: [compartimentId], references: [id], onDelete: Cascade)
  stock           Stock?           @relation(fields: [stockId], references: [id], onDelete: SetNull)
  checkupArticles CheckupArticle[]
}

model Stock {
  id                 Int       @id @default(autoincrement())
  nom                String
  photo              String?
  codeBarre          String?
  quantiteDisponible Int       @default(0)
  datePeremption     DateTime?
  seuilAlerte        Int       @default(5)

  articles Article[]
}

model Checkup {
  id    Int      @id @default(autoincrement())
  sacId Int
  date  DateTime @default(now())
  note  String?

  sac             Sac              @relation(fields: [sacId], references: [id], onDelete: Cascade)
  checkupArticles CheckupArticle[]
}

model CheckupArticle {
  id                Int @id @default(autoincrement())
  checkupId         Int
  articleId         Int
  quantiteTrouvee   Int @default(0)
  quantiteManquante Int @default(0)
  quantitePrelevee  Int @default(0)

  checkup Checkup @relation(fields: [checkupId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}
